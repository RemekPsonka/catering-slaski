{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022"
    ],
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "jsx": "react-jsx",
    "types": [
      "node"
    ],
    "noImplicitAny": false
  },
  "include": [
    "src/**/*",
    "medusa-config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".medusa",
    "**/*.test.ts",
    "disabled",
    "disabled/**/*"
  ],
  "ts-node": {
    "transpileOnly": true
  }
}