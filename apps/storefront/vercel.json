{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": ".next",
  "devCommand": "pnpm dev",
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/products", "destination": "/menu", "permanent": true },
    { "source": "/products/account", "destination": "/konto", "permanent": true },
    { "source": "/products/cart", "destination": "/koszyk", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/api/store/:path*",
      "destination": "https://catering-slaski-backend.up.railway.app/store/:path*"
    }
  ],
  "env": {
    "NEXT_PUBLIC_SITE_NAME": "Catering Śląski"
  },
  "github": {
    "silent": true
  },
  "crons": []
}
