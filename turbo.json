{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "MEDUSA_BACKEND_URL",
    "NEXT_PUBLIC_MEDUSA_BACKEND_URL",
    "NEXT_PUBLIC_MAPBOX_TOKEN",
    "STRIPE_API_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "RESEND_API_KEY",
    "SMSAPI_TOKEN",
    "FAKTUROWNIA_API_TOKEN",
    "FAKTUROWNIA_DOMAIN",
    "ANTHROPIC_API_KEY",
    "WEBHOOK_PRODUCTION_URL",
    "WEBHOOK_PRODUCTION_SECRET",
    "WEBHOOK_LOGISTICS_URL",
    "WEBHOOK_LOGISTICS_SECRET",
    "WEBHOOK_BILLING_URL",
    "WEBHOOK_BILLING_SECRET",
    "JWT_SECRET",
    "COOKIE_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", ".medusa/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
