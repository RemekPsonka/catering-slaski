# =============================================
# Catering Śląski — .env.example
# Stack: Vercel (frontend) + Railway (Medusa) + Supabase (DB) + Upstash (Redis)
# =============================================
# Skopiuj do .env i wypełnij wartościami.
# .env nie idzie do gita (jest w .gitignore).

# ---- General ----
NODE_ENV=development

# ====================================================================
# SUPABASE — PostgreSQL + Auth + Storage
# https://supabase.com/dashboard/project/[id]/settings/database
# ====================================================================

# Direct database connection (z PostGIS dla geometrii)
# Settings → Database → Connection string → "URI" mode → copy
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (dla Medusa migrations — pgbouncer ma limity)
DATABASE_DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase API (dla storefront — Auth + Storage)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # WAŻNE: secret, tylko backend

# CLI token (do migration scripts z mojego sandboxu)
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_PROJECT_REF=[PROJECT_REF]

# ====================================================================
# UPSTASH REDIS — cache + BullMQ queues
# https://console.upstash.com/redis/[id]
# ====================================================================

# Full Redis URL (BullMQ + cache compatibile)
REDIS_URL=rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379

# REST API (dla edge functions Vercel)
UPSTASH_REDIS_REST_URL=https://[ENDPOINT].upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ====================================================================
# RAILWAY — Medusa backend hosting
# https://railway.com/account/tokens
# ====================================================================

# Token CLI dla deploys z mojego sandboxu
RAILWAY_TOKEN=...

# Backend URL po deployu
MEDUSA_BACKEND_URL=https://catering-slaski-backend.up.railway.app

# ====================================================================
# VERCEL — Storefront hosting
# Settings → Tokens (jeśli używamy Vercel CLI)
# ====================================================================

# (opcjonalne, dla wdrażania z CLI; głównie deploy idzie przez git)
VERCEL_TOKEN=...
VERCEL_ORG_ID=...
VERCEL_PROJECT_ID=...

# ---- Storefront ----
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://catering-slaski-backend.up.railway.app
NEXT_PUBLIC_BASE_URL=https://cateringslaski.pl
NEXT_PUBLIC_SITE_NAME=Catering Śląski

# ---- Security ----
# Wygeneruj: openssl rand -base64 64
JWT_SECRET=
COOKIE_SECRET=

# ====================================================================
# STRIPE — płatności (BLIK + karta + Apple/Google Pay)
# https://dashboard.stripe.com/apikeys
# ====================================================================
STRIPE_API_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ====================================================================
# MAPBOX — geocoding + zone polygons
# https://account.mapbox.com/access-tokens
# ====================================================================
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoi...
MAPBOX_SECRET_TOKEN=sk.eyJ1Ijoi...

# ====================================================================
# ANTHROPIC — AI Generator menu
# https://console.anthropic.com/settings/keys
# ====================================================================
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ====================================================================
# RESEND — email transakcyjny
# https://resend.com/api-keys
# ====================================================================
RESEND_API_KEY=re_...
EMAIL_FROM=zamowienia@cateringslaski.pl
EMAIL_FROM_NAME=Catering Śląski

# ====================================================================
# SMSAPI.pl — SMS notyfikacje
# https://app.smsapi.pl/oauth_client
# ====================================================================
SMSAPI_TOKEN=...
SMSAPI_SENDER=CSlaski

# ====================================================================
# FAKTUROWNIA — auto-faktury VAT
# https://app.fakturownia.pl/api/info
# ====================================================================
FAKTUROWNIA_API_TOKEN=...
FAKTUROWNIA_DOMAIN=cateringslaski.fakturownia.pl

# ====================================================================
# Webhooks OUT → istniejące systemy Catering Śląski
# (uzgodnione z ops team)
# ====================================================================
WEBHOOK_PRODUCTION_URL=https://produkcja.cateringslaski.local/api/v1/orders/incoming
WEBHOOK_PRODUCTION_SECRET=

WEBHOOK_LOGISTICS_URL=https://logistyka.cateringslaski.local/api/v1/deliveries/incoming
WEBHOOK_LOGISTICS_SECRET=

WEBHOOK_BILLING_URL=https://rozliczenia.cateringslaski.local/api/v1/transactions/incoming
WEBHOOK_BILLING_SECRET=

# ====================================================================
# Webhooks IN ← od istniejących systemów
# ====================================================================
WEBHOOK_IN_PRODUCTION_SECRET=
WEBHOOK_IN_LOGISTICS_SECRET=

# ====================================================================
# Monitoring
# ====================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ====================================================================
# Admin
# ====================================================================
ADMIN_EMAIL=r.psonka@nono.pl
ADMIN_PASSWORD=CHANGE_ME_first_login

# ====================================================================
# GitHub — dla CI/CD
# https://github.com/settings/personal-access-tokens
# ====================================================================
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=nono-food/catering-slaski
