<script>
// === Filter chips toggle ===
document.querySelectorAll('.filter-chip').forEach(chip => {
  chip.addEventListener('click', () => {
    document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active','bg-coal-900','text-cream-100'));
    chip.classList.add('active','bg-coal-900','text-cream-100');
  });
});

// === Mini filter toggle ===
document.querySelectorAll('.filter-mini').forEach(btn => {
  btn.addEventListener('click', () => {
    btn.classList.toggle('bg-coal-900');
    btn.classList.toggle('text-cream-100');
  });
});

// === Countdown ===
const countdownEl = document.getElementById('countdown');
let secs = 6 * 3600 + 23 * 60 + 14;
setInterval(() => {
  secs = Math.max(0, secs - 1);
  const h = String(Math.floor(secs / 3600)).padStart(2,'0');
  const m = String(Math.floor((secs % 3600) / 60)).padStart(2,'0');
  const s = String(secs % 60).padStart(2,'0');
  countdownEl.textContent = `${h}:${m}:${s}`;
}, 1000);
</script>

